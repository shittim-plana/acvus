=== main ===
     0 │   r0 = context_project @out
     1 │   r1 = context_load r0
     2 │   r2 = context_project @user
     3 │   r3 = context_load r2
     5 │   r4 = test has_key(r3, "name")
     6 │   r5 = r3.name
     8 │   r6 = true (r7) && true (r8)
     9 │   r9 = test has_key(r3, "age")
    10 │   r10 = r3.age
    12 │   r11 = r6 && true (r12)
    13 │   jump_if r11 then L0 else L1(r1)
    14 │ L0:
    15 │   r13 = r3.name
    16 │   r14 = r3.age
    17 │   jump L1(r13)
    18 │ L1(r15: <error>):
    19 │   r16 = context_project @out
    20 │   ctx_store r16 = r15
    21 │   return r15

