    15 │   ctx_store r13 = r12
    16 │   iter_step r14, r15 = r11 else L4()
    17 │ L5:
    18 │   r16 = context_project @sum
    19 │   r17 = context_load r16
    20 │   r18 = r17 + r14
    21 │   jump L3(r15, r18)
    22 │ L4:
    23 │   jump L0(r9, r12)
    24 │ L1:
    25 │   r19 = context_project @sum
    26 │   r20 = context_load r19
    27 │   return r20

