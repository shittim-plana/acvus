=== main ===
     0 │   r0 = ref @stats
     1 │   r1 = ref @stats
     2 │   r2 = load r1
     3 │   r3 = r2.count
     5 │   r4 = r3 + 1 (r5)
     6 │   r3 = r2.threshold
     7 │   r6 = r4 > r3
     8 │   r7 = test true (r6) == true
    10 │   r8 = field_set r2.exceeded = true (r6)
    11 │   jump_if r7 then L0 else L1(r2)
    12 │ L0:
    13 │   jump L1(r8)
    14 │ L1(r2: {count: Int, exceeded: Bool, threshold: Int}):
    15 │   store r0 = r2
    16 │   return r2

